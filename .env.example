# Backend — local .env OR Hostinger Environment Variables panel

PORT=5000
HOST=0.0.0.0

# Comma-separated frontend origins (CORS)
FRONTEND_URL=http://localhost:8080,http://localhost:5173

# MySQL — Hostinger hPanel → Databases → MySQL Databases
DB_HOST=localhost
DB_PORT=3306
DB_USER=your_mysql_user
DB_PASSWORD=your_mysql_password
DB_NAME=your_database_name
DB_SSL=false
DB_CONNECT_TIMEOUT_MS=8000

# Hostinger example (from hPanel):
# DB_HOST=localhost
# DB_USER=u123456789_crm
# DB_PASSWORD=your_db_password
# DB_NAME=u123456789_crm_dashboard

# Optional Redis cache
REDIS_URL=

LOG_LEVEL=info
ASSIGNMENT_QUEUE_INTERVAL_MS=30000
FOLLOWUP_REMINDER_INTERVAL_MS=300000
MAX_UPLOAD_BYTES=10485760
